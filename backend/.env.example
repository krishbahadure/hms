# HMS Backend – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.

# ── MySQL (local) ─────────────────────────────────────────────
# Format: mysql+aiomysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=mysql+aiomysql://root:your_password@127.0.0.1:3306/hms_db

# ── Local PDF Storage ─────────────────────────────────────────
# Directory where generated PDFs are saved.
# PDFs are served via the FastAPI /files/... static mount.
PDF_STORAGE_DIR=./pdfs

# ── JWT Authentication (for real auth implementation) ─────────
JWT_SECRET_KEY=change-this-to-a-long-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── App Settings ──────────────────────────────────────────────
APP_ENV=development          # development | production
APP_PORT=8000
TOTAL_BEDS=100               # Total hospital bed capacity for occupancy rate calculation
AVG_CONSULT_MINUTES=15       # Average OPD consultation time in minutes (for wait estimation)
QUEUE_REFRESH_INTERVAL=20    # Seconds between automatic queue priority refreshes